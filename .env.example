# ─── Database ─────────────────────────────────────────────────────────────────
# Phải khớp với POSTGRES_* vars bên dưới
DATABASE_URL="postgresql://studio:CHANGE_ME@127.0.0.1:5432/studio_db"

# ─── PostgreSQL Docker ────────────────────────────────────────────────────────
# Dùng bởi docker-compose.yml
POSTGRES_USER="studio"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="studio_db"

# ─── Auth.js v5 ───────────────────────────────────────────────────────────────
# Tạo bằng: openssl rand -base64 32
AUTH_SECRET="your-secret-key-min-32-characters-here"
AUTH_URL="http://localhost:3000"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"

# ─── Development only ─────────────────────────────────────────────────────────
# KHÔNG SET trong staging hay production — bỏ qua toàn bộ auth khi true
# AUTH_BYPASS_DEV="true"
