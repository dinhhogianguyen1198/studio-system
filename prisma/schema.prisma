generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js required models ──────────────────────────────────────────────────

model User {
  id               String                 @id @default(cuid())
  email            String                 @unique
  emailVerified    DateTime?
  password         String?
  name             String?
  image            String?
  roleId           String
  role             Role                   @relation(fields: [roleId], references: [id])
  accounts         Account[]
  sessions         Session[]
  auditLogs        AuditLog[]
  customers        Customer[]             @relation("CustomerCreator")
  createdLeads     Lead[]                 @relation("LeadCreator")
  assignedLeads    Lead[]                 @relation("LeadAssignee")
  customerNotes    CustomerNote[]         @relation("CustomerNoteAuthor")
  leadNotes        LeadNote[]             @relation("LeadNoteAuthor")
  // ── Service Catalog ──
  createdServiceDefs       ServiceDefinition[]    @relation("ServiceDefinitionCreator")
  createdWorkflowTemplates WorkflowTemplate[]     @relation("WorkflowTemplateCreator")
  // ── Orders ──
  createdOrders            Order[]                @relation("OrderCreator")
  assignedOrderItems       OrderItem[]            @relation("OrderItemAssignee")
  recordedPayments         OrderPayment[]         @relation("PaymentRecorder")
  workflowLogs             OrderItemWorkflowLog[] @relation("WorkflowLogChanger")
  createdWorkers           Worker[]               @relation("WorkerCreator")
  createdJobTypes          JobType[]              @relation("JobTypeCreator")
  workerAssignments        OrderItemWorker[]      @relation("WorkerAssigner")
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── RBAC models ──────────────────────────────────────────────────────────────

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  action      String           // create | read | update | delete | manage
  resource    String           // users | roles | permissions | settings | audit_logs
  description String?
  roles       RolePermission[]

  @@unique([action, resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─── CRM models ───────────────────────────────────────────────────────────────

model Customer {
  id          String         @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  address     String?
  status      CustomerStatus @default(ACTIVE)
  source      CustomerSource @default(DIRECT)
  tags        String[]
  notes       CustomerNote[]
  leads       Lead[]
  orders      Order[]
  createdById String
  createdBy   User           @relation("CustomerCreator", fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([email])
  @@index([status])
  @@index([name])
  @@index([createdAt])
  @@map("customers")
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum CustomerSource {
  DIRECT
  REFERRAL
  SOCIAL_MEDIA
  WEBSITE
  EVENT
  OTHER
}

model Lead {
  id                String       @id @default(cuid())
  title             String
  customerId        String?
  customer          Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contactName       String
  contactEmail      String?
  contactPhone      String?
  value             Decimal?     @db.Decimal(15, 2)
  currency          String       @default("VND")
  status            LeadStatus   @default(NEW)
  priority          LeadPriority @default(MEDIUM)
  source            CustomerSource @default(DIRECT)
  notes             LeadNote[]
  assignedToId      String?
  assignedTo        User?        @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById       String
  createdBy         User         @relation("LeadCreator", fields: [createdById], references: [id])
  expectedCloseDate DateTime?
  closedAt          DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([assignedToId])
  @@index([createdAt])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  authorId   String
  author     User     @relation("CustomerNoteAuthor", fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([customerId])
  @@map("customer_notes")
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  authorId  String
  author    User     @relation("LeadNoteAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@map("lead_notes")
}

// ─── SERVICE CATALOG ──────────────────────────────────────────────────────────

model ServiceDefinition {
  id                 String            @id @default(cuid())
  name               String
  slug               String            @unique
  description        String?           @db.Text
  defaultPrice       Decimal           @db.Decimal(15, 2)
  currency           String            @default("VND")
  defaultDurationDays Int              @default(3)
  defaultSlaHours    Int               @default(72)
  isActive           Boolean           @default(true)
  sortOrder          Int               @default(0)
  workflowTemplateId String?
  workflowTemplate   WorkflowTemplate? @relation(fields: [workflowTemplateId], references: [id], onDelete: SetNull)
  orderItems         OrderItem[]
  workerRates        WorkerRate[]           @relation("ServiceDefinitionRates")
  createdById        String
  createdBy          User              @relation("ServiceDefinitionCreator", fields: [createdById], references: [id])
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([isActive])
  @@index([slug])
  @@map("service_definitions")
}

// ─── WORKFLOW TEMPLATES ────────────────────────────────────────────────────────

model WorkflowTemplate {
  id          String              @id @default(cuid())
  name        String
  description String?
  steps       WorkflowStep[]
  services    ServiceDefinition[]
  createdById String
  createdBy   User                @relation("WorkflowTemplateCreator", fields: [createdById], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("workflow_templates")
}

model WorkflowStep {
  id                  String                   @id @default(cuid())
  templateId          String
  template            WorkflowTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key                 String
  name                String
  description         String?
  color               String?
  sortOrder           Int                      @default(0)
  isFinal             Boolean                  @default(false)
  outgoingTransitions WorkflowStepTransition[] @relation("TransitionFrom")
  incomingTransitions WorkflowStepTransition[] @relation("TransitionTo")
  currentOrderItems   OrderItem[]              @relation("CurrentStep")
  workflowLogs        OrderItemWorkflowLog[]   @relation("LogToStep")

  @@unique([templateId, key])
  @@index([templateId])
  @@map("workflow_steps")
}

model WorkflowStepTransition {
  id          String       @id @default(cuid())
  fromStepId  String
  fromStep    WorkflowStep @relation("TransitionFrom", fields: [fromStepId], references: [id], onDelete: Cascade)
  toStepId    String
  toStep      WorkflowStep @relation("TransitionTo", fields: [toStepId], references: [id], onDelete: Cascade)
  label       String?
  requireNote Boolean      @default(false)

  @@unique([fromStepId, toStepId])
  @@index([fromStepId])
  @@map("workflow_step_transitions")
}

// ─── ORDERS ───────────────────────────────────────────────────────────────────

model Order {
  id            String         @id @default(cuid())
  orderNumber   String         @unique
  customerId    String?
  customer      Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contactName   String
  contactPhone  String?
  contactEmail  String?
  status        OrderStatus    @default(DRAFT)
  notes         String?        @db.Text
  internalNotes String?        @db.Text
  subtotal      Decimal        @default(0) @db.Decimal(15, 2)
  discountAmount Decimal       @default(0) @db.Decimal(15, 2)
  totalAmount   Decimal        @default(0) @db.Decimal(15, 2)
  paidAmount    Decimal        @default(0) @db.Decimal(15, 2)
  currency      String         @default("VND")
  // ── Thông tin tiệc ──
  partyName   String?
  // ── Lịch trình sản xuất ──
  shootingDate        DateTime?
  rawPhotoSentDate    DateTime?
  selectionDate       DateTime?
  editedPhotoSentDate DateTime?
  deliveryDate        DateTime?
  // ── Phân loại ──
  category    String?
  channel     String?

  source      CustomerSource?
  items         OrderItem[]
  payments      OrderPayment[]
  createdById   String
  createdBy     User           @relation("OrderCreator", fields: [createdById], references: [id])
  confirmedAt   DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([orderNumber])
  @@index([createdById])
  @@index([createdAt])
  @@index([shootingDate])
  @@map("orders")
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model OrderItem {
  id                  String                 @id @default(cuid())
  orderId             String
  order               Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceDefinitionId String
  serviceDefinition   ServiceDefinition      @relation(fields: [serviceDefinitionId], references: [id])
  name                String
  description         String?                @db.Text
  price               Decimal                @db.Decimal(15, 2)
  quantity            Int                    @default(1)
  totalPrice          Decimal                @db.Decimal(15, 2)
  eventDate           DateTime?
  deadline            DateTime?
  currentStepId       String?
  currentStep         WorkflowStep?          @relation("CurrentStep", fields: [currentStepId], references: [id], onDelete: SetNull)
  assignedToId        String?
  assignedTo          User?                  @relation("OrderItemAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes               String?                @db.Text
  workflowLogs        OrderItemWorkflowLog[]
  workerAssignments   OrderItemWorker[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([orderId])
  @@index([serviceDefinitionId])
  @@index([currentStepId])
  @@index([assignedToId])
  @@index([deadline])
  @@map("order_items")
}

model OrderItemWorkflowLog {
  id          String        @id @default(cuid())
  orderItemId String
  orderItem   OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  fromStepId  String?
  fromStep    WorkflowStep? @relation("LogToStep", fields: [fromStepId], references: [id], onDelete: SetNull)
  toStepKey   String
  toStepName  String
  note        String?       @db.Text
  changedById String
  changedBy   User          @relation("WorkflowLogChanger", fields: [changedById], references: [id])
  createdAt   DateTime      @default(now())

  @@index([orderItemId])
  @@index([createdAt])
  @@map("order_item_workflow_logs")
}

model OrderPayment {
  id           String        @id @default(cuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type         PaymentType   @default(DEPOSIT)
  amount       Decimal       @db.Decimal(15, 2)
  method       PaymentMethod @default(BANK_TRANSFER)
  reference    String?
  note         String?
  paidAt       DateTime      @default(now())
  recordedById String
  recordedBy   User          @relation("PaymentRecorder", fields: [recordedById], references: [id])
  createdAt    DateTime      @default(now())

  @@index([orderId])
  @@index([paidAt])
  @@map("order_payments")
}

enum PaymentType {
  DEPOSIT
  PARTIAL
  FINAL
  REFUND
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

// ─── Audit log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([resource, action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── WORKFORCE MANAGEMENT ─────────────────────────────────────────────────────

model Worker {
  id          String            @id @default(cuid())
  name        String
  phone       String?
  email       String?
  avatarUrl   String?
  notes       String?           @db.Text
  isActive    Boolean           @default(true)
  jobTypes    WorkerJobType[]
  rates       WorkerRate[]
  assignments OrderItemWorker[]
  createdById String
  createdBy   User              @relation("WorkerCreator", fields: [createdById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([isActive])
  @@index([name])
  @@index([email])
  @@index([createdAt])
  @@map("workers")
}

model JobType {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  color       String            @default("#6B7280")
  isActive    Boolean           @default(true)
  sortOrder   Int               @default(0)
  description String?
  workers     WorkerJobType[]
  rates       WorkerRate[]
  assignments OrderItemWorker[]
  createdById String
  createdBy   User              @relation("JobTypeCreator", fields: [createdById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([isActive])
  @@index([slug])
  @@index([sortOrder])
  @@map("job_types")
}

model WorkerJobType {
  workerId  String
  jobTypeId String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  jobType   JobType  @relation(fields: [jobTypeId], references: [id], onDelete: Cascade)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@id([workerId, jobTypeId])
  @@index([workerId])
  @@index([jobTypeId])
  @@map("worker_job_types")
}

enum RateType {
  PER_JOB
  HOURLY
  DAILY
}

model WorkerRate {
  id                  String             @id @default(cuid())
  workerId            String
  worker              Worker             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  jobTypeId           String
  jobType             JobType            @relation(fields: [jobTypeId], references: [id], onDelete: Cascade)
  serviceDefinitionId String?
  serviceDefinition   ServiceDefinition? @relation("ServiceDefinitionRates", fields: [serviceDefinitionId], references: [id], onDelete: SetNull)
  rateType            RateType           @default(PER_JOB)
  amount              Decimal            @db.Decimal(15, 2)
  currency            String             @default("VND")
  isActive            Boolean            @default(true)
  effectiveFrom       DateTime           @default(now())
  effectiveTo         DateTime?
  note                String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([workerId])
  @@index([jobTypeId])
  @@index([serviceDefinitionId])
  @@index([isActive])
  @@map("worker_rates")
}

enum WorkerAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model OrderItemWorker {
  id                  String                 @id @default(cuid())
  orderItemId         String
  orderItem           OrderItem              @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  workerId            String
  worker              Worker                 @relation(fields: [workerId], references: [id], onDelete: Cascade)
  jobTypeId           String
  jobType             JobType                @relation(fields: [jobTypeId], references: [id])
  workerNameSnapshot  String
  jobTypeNameSnapshot String
  rateTypeSnapshot    RateType
  rateAmountSnapshot  Decimal                @db.Decimal(15, 2)
  quantity            Decimal                @default(1) @db.Decimal(10, 2)
  totalCost           Decimal                @db.Decimal(15, 2)
  status              WorkerAssignmentStatus @default(ASSIGNED)
  notes               String?                @db.Text
  startedAt           DateTime?
  completedAt         DateTime?
  assignedById        String
  assignedBy          User                   @relation("WorkerAssigner", fields: [assignedById], references: [id])
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([orderItemId, workerId, jobTypeId])
  @@index([orderItemId])
  @@index([workerId])
  @@index([jobTypeId])
  @@index([status])
  @@index([createdAt])
  @@map("order_item_workers")
}
