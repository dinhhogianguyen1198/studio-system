generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                 @id @default(cuid())
  email            String                 @unique
  emailVerified    DateTime?
  password         String?
  name             String?
  image            String?
  roleId           String
  role             Role                   @relation("UserPrimaryRole", fields: [roleId], references: [id])
  userRoles        UserRole[]             @relation("UserRoleUser")
  assignedUserRoles UserRole[]            @relation("UserRoleAssigner")
  createdRoles     Role[]                 @relation("RoleCreator")
  updatedRoles     Role[]                 @relation("RoleUpdater")
  accounts         Account[]
  sessions         Session[]
  auditLogs        AuditLog[]
  customers        Customer[]             @relation("CustomerCreator")
  createdLeads     Lead[]                 @relation("LeadCreator")
  assignedLeads    Lead[]                 @relation("LeadAssignee")
  customerNotes    CustomerNote[]         @relation("CustomerNoteAuthor")
  leadNotes        LeadNote[]             @relation("LeadNoteAuthor")
  createdServiceDefs       ServiceDefinition[]    @relation("ServiceDefinitionCreator")
  createdWorkflowTemplates WorkflowTemplate[]     @relation("WorkflowTemplateCreator")
  createdOrders            Order[]                @relation("OrderCreator")
  assignedOrderItems       OrderItem[]            @relation("OrderItemAssignee")
  recordedPayments         OrderPayment[]         @relation("PaymentRecorder")
  workflowLogs             OrderItemWorkflowLog[] @relation("WorkflowLogChanger")
  createdWorkers           Worker[]               @relation("WorkerCreator")
  createdJobTypes          JobType[]              @relation("JobTypeCreator")
  workerAssignments        OrderItemWorker[]      @relation("WorkerAssigner")
  createdOrderManagementUnits OrderManagementUnit[] @relation("OrderManagementUnitCreator")
  createdFeedbacks         OrderFeedback[]        @relation("FeedbackCreator")
  createdIncidentalCosts   OrderIncidentalCost[]  @relation("IncidentalCostCreator")
  createdExpenses          Expense[]              @relation("ExpenseCreator")
  updatedExpenses          Expense[]              @relation("ExpenseUpdater")
  approvedExpenses         Expense[]              @relation("ExpenseApprover")
  createdInvoices          Invoice[]              @relation("InvoiceCreator")
  createdFreelancerPayments FreelancerPayment[]   @relation("FreelancerPaymentCreator")
  paidFreelancerPayments   FreelancerPayment[]    @relation("FreelancerPaymentPaidBy")
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  @@index([roleId])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  users       User[]           @relation("UserPrimaryRole")
  userRoles   UserRole[]
  permissions RolePermission[]
  createdById String?
  updatedById String?
  createdBy   User?            @relation("RoleCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy   User?            @relation("RoleUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  @@index([isSystem])
  @@index([deletedAt])
  @@map("roles")
}

model UserRole {
  id           String   @id @default(cuid())
  userId       String
  roleId       String
  user         User     @relation("UserRoleUser", fields: [userId], references: [id], onDelete: Cascade)
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedById String
  assignedBy   User     @relation("UserRoleAssigner", fields: [assignedById], references: [id])
  assignedAt   DateTime @default(now())
  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([assignedById])
  @@map("user_roles")
}

model Permission {
  id          String           @id @default(cuid())
  action      String
  resource    String
  description String?
  roles       RolePermission[]
  deletedAt   DateTime?
  @@unique([action, resource])
  @@index([resource])
  @@index([action])
  @@index([deletedAt])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  assignedById String?
  assignedAt   DateTime   @default(now())
  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Customer {
  id          String         @id @default(cuid())
  name        String
  email       String?
  phone       String?
  company     String?
  address     String?
  status      CustomerStatus @default(ACTIVE)
  source      CustomerSource @default(DIRECT)
  tags        String[]
  notes       CustomerNote[]
  leads       Lead[]
  orders      Order[]
  invoices    Invoice[]
  createdById String
  createdBy   User           @relation("CustomerCreator", fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  @@index([email])
  @@index([status])
  @@index([name])
  @@index([createdAt])
  @@index([createdById])
  @@map("customers")
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum CustomerSource {
  DIRECT
  REFERRAL
  SOCIAL_MEDIA
  WEBSITE
  EVENT
  OTHER
}

model Lead {
  id                String         @id @default(cuid())
  title             String
  customerId        String?
  customer          Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contactName       String
  contactEmail      String?
  contactPhone      String?
  value             Decimal?       @db.Decimal(15, 2)
  currency          String         @default("VND")
  status            LeadStatus     @default(NEW)
  priority          LeadPriority   @default(MEDIUM)
  source            CustomerSource @default(DIRECT)
  notes             LeadNote[]
  assignedToId      String?
  assignedTo        User?          @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById       String
  createdBy         User           @relation("LeadCreator", fields: [createdById], references: [id])
  expectedCloseDate DateTime?
  closedAt          DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  @@index([status])
  @@index([priority])
  @@index([customerId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([createdAt])
  @@index([closedAt])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  authorId   String
  author     User     @relation("CustomerNoteAuthor", fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([customerId])
  @@map("customer_notes")
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  authorId  String
  author    User     @relation("LeadNoteAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([leadId])
  @@map("lead_notes")
}

model ServiceDefinition {
  id                  String            @id @default(cuid())
  name                String
  slug                String            @unique
  description         String?           @db.Text
  defaultPrice        Decimal           @db.Decimal(15, 2)
  currency            String            @default("VND")
  defaultDurationDays Int               @default(3)
  defaultSlaHours     Int               @default(72)
  isActive            Boolean           @default(true)
  sortOrder           Int               @default(0)
  workflowTemplateId  String?
  workflowTemplate    WorkflowTemplate? @relation(fields: [workflowTemplateId], references: [id], onDelete: SetNull)
  orderItems          OrderItem[]
  workerRates         WorkerRate[]      @relation("ServiceDefinitionRates")
  createdById         String
  createdBy           User              @relation("ServiceDefinitionCreator", fields: [createdById], references: [id])
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  @@index([isActive])
  @@index([slug])
  @@map("service_definitions")
}

model WorkflowTemplate {
  id          String              @id @default(cuid())
  name        String
  description String?
  steps       WorkflowStep[]
  services    ServiceDefinition[]
  createdById String
  createdBy   User                @relation("WorkflowTemplateCreator", fields: [createdById], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  @@map("workflow_templates")
}

model WorkflowStep {
  id                  String                   @id @default(cuid())
  templateId          String
  template            WorkflowTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key                 String
  name                String
  description         String?
  color               String?
  sortOrder           Int                      @default(0)
  isFinal             Boolean                  @default(false)
  outgoingTransitions WorkflowStepTransition[] @relation("TransitionFrom")
  incomingTransitions WorkflowStepTransition[] @relation("TransitionTo")
  currentOrderItems   OrderItem[]              @relation("CurrentStep")
  workflowLogs        OrderItemWorkflowLog[]   @relation("LogToStep")
  @@unique([templateId, key])
  @@index([templateId])
  @@map("workflow_steps")
}

model WorkflowStepTransition {
  id          String       @id @default(cuid())
  fromStepId  String
  fromStep    WorkflowStep @relation("TransitionFrom", fields: [fromStepId], references: [id], onDelete: Cascade)
  toStepId    String
  toStep      WorkflowStep @relation("TransitionTo", fields: [toStepId], references: [id], onDelete: Cascade)
  label       String?
  requireNote Boolean      @default(false)
  @@unique([fromStepId, toStepId])
  @@index([fromStepId])
  @@map("workflow_step_transitions")
}

model Order {
  id                    String                @id @default(cuid())
  orderNumber           String                @unique
  customerId            String?
  customer              Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contactName           String
  contactPhone          String?
  contactEmail          String?
  status                OrderStatus           @default(NEW)
  notes                 String?               @db.Text
  internalNotes         String?               @db.Text
  subtotal              Decimal               @default(0) @db.Decimal(15, 2)
  discountAmount        Decimal               @default(0) @db.Decimal(15, 2)
  totalAmount           Decimal               @default(0) @db.Decimal(15, 2)
  paidAmount            Decimal               @default(0) @db.Decimal(15, 2)
  currency              String                @default("VND")
  partyName             String?
  source                CustomerSource?
  orderManagementUnitId String?
  orderManagementUnit   OrderManagementUnit?  @relation(fields: [orderManagementUnitId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  payments              OrderPayment[]
  feedbacks             OrderFeedback[]
  incidentalCosts       OrderIncidentalCost[]
  expenses              Expense[]
  invoice               Invoice?
  createdById           String
  createdBy             User                  @relation("OrderCreator", fields: [createdById], references: [id])
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  @@index([status])
  @@index([customerId])
  @@index([orderNumber])
  @@index([createdById])
  @@index([createdAt])
  @@index([orderManagementUnitId])
  @@map("orders")
}

model OrderManagementUnit {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  orders      Order[]
  createdById String
  createdBy   User     @relation("OrderManagementUnitCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([isActive])
  @@index([sortOrder])
  @@map("order_management_units")
}

enum OrderStatus {
  NEW
  WAITING_FILES
  PARTIAL_DELIVERY
  OVERDUE
  FILES_DELIVERED
  COMPLETED
}

enum OrderItemDeliveryStatus {
  PENDING
  DELIVERED
}

model OrderItem {
  id                  String                  @id @default(cuid())
  orderId             String
  order               Order                   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serviceDefinitionId String
  serviceDefinition   ServiceDefinition       @relation(fields: [serviceDefinitionId], references: [id])
  name                String
  description         String?                 @db.Text
  price               Decimal                 @db.Decimal(15, 2)
  quantity            Int                     @default(1)
  totalPrice          Decimal                 @db.Decimal(15, 2)
  eventDate           DateTime?
  deadline            DateTime?
  deliveryStatus      OrderItemDeliveryStatus @default(PENDING)
  fileDeliveredAt     DateTime?
  currentStepId       String?
  currentStep         WorkflowStep?           @relation("CurrentStep", fields: [currentStepId], references: [id], onDelete: SetNull)
  assignedToId        String?
  assignedTo          User?                   @relation("OrderItemAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  notes               String?                 @db.Text
  location            String?                 @db.Text
  workflowLogs        OrderItemWorkflowLog[]
  workerAssignments   OrderItemWorker[]
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  @@index([orderId])
  @@index([serviceDefinitionId])
  @@index([currentStepId])
  @@index([assignedToId])
  @@index([deadline])
  @@index([deliveryStatus])
  @@map("order_items")
}

model OrderItemWorkflowLog {
  id          String        @id @default(cuid())
  orderItemId String
  orderItem   OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  fromStepId  String?
  fromStep    WorkflowStep? @relation("LogToStep", fields: [fromStepId], references: [id], onDelete: SetNull)
  toStepKey   String
  toStepName  String
  note        String?       @db.Text
  changedById String
  changedBy   User          @relation("WorkflowLogChanger", fields: [changedById], references: [id])
  createdAt   DateTime      @default(now())
  @@index([orderItemId])
  @@index([createdAt])
  @@map("order_item_workflow_logs")
}

model OrderPayment {
  id           String        @id @default(cuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type         PaymentType   @default(DEPOSIT)
  amount       Decimal       @db.Decimal(15, 2)
  method       PaymentMethod @default(BANK_TRANSFER)
  reference    String?
  note         String?
  paidAt       DateTime      @default(now())
  recordedById String
  recordedBy   User          @relation("PaymentRecorder", fields: [recordedById], references: [id])
  createdAt    DateTime      @default(now())
  @@index([orderId])
  @@index([paidAt])
  @@map("order_payments")
}

enum PaymentType {
  DEPOSIT
  PARTIAL
  FINAL
  REFUND
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

model OrderFeedback {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  content     String   @db.Text
  createdById String
  createdBy   User     @relation("FeedbackCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([orderId])
  @@index([createdAt])
  @@map("order_feedbacks")
}

model OrderIncidentalCost {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason      String
  amount      Decimal  @db.Decimal(15, 2)
  notes       String?  @db.Text
  createdById String
  createdBy   User     @relation("IncidentalCostCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([orderId])
  @@map("order_incidental_costs")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([resource, action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Worker {
  id          String            @id @default(cuid())
  name        String
  phone       String?
  email       String?
  avatarUrl   String?
  notes       String?           @db.Text
  isActive           Boolean             @default(true)
  jobTypes           WorkerJobType[]
  rates              WorkerRate[]
  assignments        OrderItemWorker[]
  freelancerPayments FreelancerPayment[]
  createdById        String
  createdBy   User              @relation("WorkerCreator", fields: [createdById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  @@index([isActive])
  @@index([name])
  @@index([email])
  @@index([createdAt])
  @@map("workers")
}

model JobType {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  color       String            @default("#6B7280")
  isActive    Boolean           @default(true)
  sortOrder   Int               @default(0)
  description String?
  workers     WorkerJobType[]
  rates       WorkerRate[]
  assignments OrderItemWorker[]
  createdById String
  createdBy   User              @relation("JobTypeCreator", fields: [createdById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  @@index([isActive])
  @@index([slug])
  @@index([sortOrder])
  @@map("job_types")
}

model WorkerJobType {
  workerId  String
  jobTypeId String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  jobType   JobType  @relation(fields: [jobTypeId], references: [id], onDelete: Cascade)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  @@id([workerId, jobTypeId])
  @@index([workerId])
  @@index([jobTypeId])
  @@map("worker_job_types")
}

enum RateType {
  PER_JOB
  HOURLY
  DAILY
}

model WorkerRate {
  id                  String             @id @default(cuid())
  workerId            String
  worker              Worker             @relation(fields: [workerId], references: [id], onDelete: Cascade)
  jobTypeId           String
  jobType             JobType            @relation(fields: [jobTypeId], references: [id], onDelete: Cascade)
  serviceDefinitionId String?
  serviceDefinition   ServiceDefinition? @relation("ServiceDefinitionRates", fields: [serviceDefinitionId], references: [id], onDelete: SetNull)
  rateType            RateType           @default(PER_JOB)
  amount              Decimal            @db.Decimal(15, 2)
  currency            String             @default("VND")
  isActive            Boolean            @default(true)
  effectiveFrom       DateTime           @default(now())
  effectiveTo         DateTime?
  note                String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  @@index([workerId])
  @@index([jobTypeId])
  @@index([serviceDefinitionId])
  @@index([isActive])
  @@map("worker_rates")
}

enum WorkerAssignmentStatus {
  IN_PROGRESS
  COMPLETED
}

model OrderItemWorker {
  id                  String                 @id @default(cuid())
  orderItemId         String
  orderItem           OrderItem              @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  workerId            String
  worker              Worker                 @relation(fields: [workerId], references: [id], onDelete: Cascade)
  jobTypeId           String
  jobType             JobType                @relation(fields: [jobTypeId], references: [id])
  workerNameSnapshot  String
  jobTypeNameSnapshot String
  rateTypeSnapshot    RateType
  rateAmountSnapshot  Decimal                @db.Decimal(15, 2)
  quantity            Decimal                @default(1) @db.Decimal(10, 2)
  totalCost           Decimal                @db.Decimal(15, 2)
  status              WorkerAssignmentStatus @default(IN_PROGRESS)
  notes               String?                @db.Text
  startedAt           DateTime?
  completedAt         DateTime?
  paidAt              DateTime?
  assignedById        String
  assignedBy          User                   @relation("WorkerAssigner", fields: [assignedById], references: [id])
  freelancerPaymentItem FreelancerPaymentItem?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  @@unique([orderItemId, workerId, jobTypeId])
  @@index([orderItemId])
  @@index([workerId])
  @@index([jobTypeId])
  @@index([status])
  @@index([paidAt])
  @@index([createdAt])
  @@map("order_item_workers")
}

// ==================== FINANCE ====================

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL
  PAID
  OVERDUE
  CANCELLED
}

enum AccountType {
  CASH
  BANK
  E_WALLET
  OTHER
}

enum FreelancerPaymentStatus {
  PENDING
  PROCESSING
  PAID
  CANCELLED
}

model ExpenseCategory {
  id          String            @id @default(cuid())
  name        String            @unique
  slug        String            @unique
  description String?
  color       String?           @default("#6B7280")
  parentId    String?
  parent      ExpenseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    ExpenseCategory[] @relation("CategoryHierarchy")
  isActive    Boolean           @default(true)
  sortOrder   Int               @default(0)
  expenses    Expense[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  @@index([parentId])
  @@index([isActive])
  @@map("expense_categories")
}

model Expense {
  id            String          @id @default(cuid())
  title         String
  amount        Decimal         @db.Decimal(15, 2)
  currency      String          @default("VND")
  categoryId    String
  category      ExpenseCategory @relation(fields: [categoryId], references: [id])
  orderId       String?
  order         Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  expenseDate   DateTime
  status        ExpenseStatus   @default(PENDING)
  approvedById  String?
  approvedBy    User?           @relation("ExpenseApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt    DateTime?
  paymentMethod PaymentMethod?
  reference     String?
  notes         String?         @db.Text
  attachments   String[]
  createdById   String
  createdBy     User            @relation("ExpenseCreator", fields: [createdById], references: [id])
  updatedById   String?
  updatedBy     User?           @relation("ExpenseUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  @@index([categoryId])
  @@index([orderId])
  @@index([status])
  @@index([expenseDate])
  @@index([createdById])
  @@index([deletedAt])
  @@map("expenses")
}

model Invoice {
  id             String        @id @default(cuid())
  invoiceNumber  String        @unique
  orderId        String?       @unique
  order          Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status         InvoiceStatus @default(DRAFT)
  issueDate      DateTime      @default(now())
  dueDate        DateTime
  subtotal       Decimal       @default(0) @db.Decimal(15, 2)
  discountAmount Decimal       @default(0) @db.Decimal(15, 2)
  taxAmount      Decimal       @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal       @default(0) @db.Decimal(15, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(15, 2)
  currency       String        @default("VND")
  notes          String?       @db.Text
  terms          String?       @db.Text
  items          InvoiceItem[]
  sentAt         DateTime?
  paidAt         DateTime?
  cancelledAt    DateTime?
  createdById    String
  createdBy      User          @relation("InvoiceCreator", fields: [createdById], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  @@index([status])
  @@index([customerId])
  @@index([dueDate])
  @@index([createdById])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(15, 2)
  totalPrice  Decimal @db.Decimal(15, 2)
  sortOrder   Int     @default(0)
  @@index([invoiceId])
  @@map("invoice_items")
}

model FinancialAccount {
  id            String      @id @default(cuid())
  name          String      @unique
  type          AccountType
  bankName      String?
  accountNumber String?
  balance       Decimal     @default(0) @db.Decimal(15, 2)
  currency      String      @default("VND")
  isActive      Boolean     @default(true)
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  @@index([type])
  @@index([isActive])
  @@map("financial_accounts")
}

model FreelancerPayment {
  id            String                  @id @default(cuid())
  workerId      String
  worker        Worker                  @relation(fields: [workerId], references: [id])
  periodStart   DateTime
  periodEnd     DateTime
  totalAmount   Decimal                 @db.Decimal(15, 2)
  currency      String                  @default("VND")
  status        FreelancerPaymentStatus @default(PENDING)
  paymentMethod PaymentMethod?
  reference     String?
  notes         String?                 @db.Text
  paidAt        DateTime?
  paidById      String?
  paidBy        User?                   @relation("FreelancerPaymentPaidBy", fields: [paidById], references: [id], onDelete: SetNull)
  items         FreelancerPaymentItem[]
  createdById   String
  createdBy     User                    @relation("FreelancerPaymentCreator", fields: [createdById], references: [id])
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  @@index([workerId])
  @@index([status])
  @@index([createdAt])
  @@map("freelancer_payments")
}

model FreelancerPaymentItem {
  id                  String            @id @default(cuid())
  freelancerPaymentId String
  freelancerPayment   FreelancerPayment @relation(fields: [freelancerPaymentId], references: [id], onDelete: Cascade)
  orderItemWorkerId   String            @unique
  orderItemWorker     OrderItemWorker   @relation(fields: [orderItemWorkerId], references: [id])
  amount              Decimal           @db.Decimal(15, 2)
  @@index([freelancerPaymentId])
  @@map("freelancer_payment_items")
}